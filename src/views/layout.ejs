<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>The Claryville Open</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
  <link rel="icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="stylesheet" href="/css/style.css">
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-R0J23BVR6X"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-R0J23BVR6X');
  </script>
</head>
<body>
  <nav class="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <img src="/media/logo.png" alt="Claryville Open" class="brand-logo">
      </a>
      <button class="nav-toggle" aria-label="Toggle navigation">&#9776;</button>
      <ul class="nav-links">
        <li><a href="/register">Register</a></li>
        <li><a href="/groups">Groups</a></li>
        <li><a href="/rules">Rules</a></li>
        <li><a href="/past-winners">Past Winners</a></li>
        <li><a href="/donate">Donate</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/leaderboard">Leaderboard</a></li>
        <li><a href="/questions">Questions</a></li>
      </ul>
    </div>
  </nav>
  <div class="sub-header">
    <div class="sub-header-inner">
      <span class="sub-header-name">The Claryville Open</span>
      <span class="sub-header-details">Lochmor Golf Club &middot; Friday, July 3, 2026</span>
    </div>
  </div>
  <main>
    <%- body %>
  </main>
  <footer class="footer">
    <div class="footer-inner">
      <img src="/media/logo.png" alt="Claryville Open" class="footer-logo">
      <div class="footer-brand">The Claryville Open</div>
      <div class="footer-text">Annual Family Scramble Tournament &middot; Est. 1993</div>
      <div class="footer-links">
        <a href="/rules">Rules</a>
        <a href="/register">Register</a>
        <a href="/gallery">Gallery</a>
        <a href="/donate">Donate</a>
        <a href="/past-winners">Past Winners</a>
      </div>
      <div class="footer-signup">
        <p class="footer-signup-label">Stay in the loop</p>
        <form method="POST" action="/subscribe" class="footer-signup-form">
          <input type="email" name="email" placeholder="Your email address" required>
          <button type="submit" class="btn btn-accent btn-small">Sign Up</button>
        </form>
      </div>
      <div class="footer-copy">&copy; <%= new Date().getFullYear() %> The Claryville Open. All proceeds benefit the Claryville Fire Department.</div>
    </div>
  </footer>
  <script src="/js/app.js"></script>
</body>
</html>
