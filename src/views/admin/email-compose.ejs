<% layout('layout') -%>
<div class="admin-header">
  <h1>Email Campaigns</h1>
</div>

<nav class="admin-nav">
  <a href="/admin">Dashboard</a>
  <a href="/admin/groups">Groups</a>
  <a href="/admin/inbox">Inbox</a>
  <a href="/admin/email" class="active">Email</a>
  <a href="/admin/scores">Scores</a>
  <a href="/admin/gallery">Gallery</a>
  <a href="/admin/rules-suggestions">Rules</a>
</nav>

<section class="admin-section">
  <h2>Compose Email</h2>
  <p class="form-hint">Will send to all <%= emailCount %> registered email addresses (<%= playerCount %> players total).</p>

  <div class="email-templates">
    <strong>Quick templates:</strong>
    <button class="btn btn-small" onclick="loadTemplate('save-the-date')">Save the Date</button>
    <button class="btn btn-small" onclick="loadTemplate('registration-open')">Registration Open</button>
    <button class="btn btn-small" onclick="loadTemplate('groups-details')">Groups & Details</button>
    <button class="btn btn-small" onclick="loadTemplate('final-call')">Final Call</button>
    <button class="btn btn-small" onclick="loadTemplate('recap')">Recap & Results</button>
  </div>

  <form method="POST" action="/admin/email/send" class="form" onsubmit="return confirm('Send this email to all ' + <%= emailCount %> + ' recipients?')">
    <div class="form-group">
      <label for="subject">Subject</label>
      <input type="text" id="subject" name="subject" required>
    </div>
    <div class="form-group">
      <label for="body">Body (HTML)</label>
      <textarea id="body" name="body" rows="15" required></textarea>
    </div>
    <div class="form-group">
      <label>Preview</label>
      <div id="preview" class="email-preview"></div>
    </div>
    <button type="submit" class="btn btn-primary">Send to All</button>
  </form>
</section>

<% if (sentEmails.length > 0) { %>
  <section class="admin-section">
    <h2>Sent Emails</h2>
    <table class="admin-table">
      <thead>
        <tr><th>Date</th><th>Subject</th><th>Recipients</th></tr>
      </thead>
      <tbody>
        <% for (const e of sentEmails) { %>
          <tr>
            <td><%= new Date(e.sent_at).toLocaleDateString() %></td>
            <td><%= e.subject %></td>
            <td><%= e.recipient_count %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </section>
<% } %>

<script>
const templates = {
  'save-the-date': {
    subject: 'The Claryville Open — Save the Date!',
    body: '<h1>The Claryville Open</h1>\n<p>Mark your calendars! The annual Claryville Open is coming up.</p>\n<p><strong>Date:</strong> July 4, 2026</p>\n<p>Registration opens soon. Stay tuned for more details!</p>'
  },
  'registration-open': {
    subject: 'The Claryville Open — Registration is Open!',
    body: '<h1>Registration is Open!</h1>\n<p>Sign up your foursome for the Claryville Open.</p>\n<p><a href="{{BASE_URL}}/register">Register here</a></p>\n<p>Don\'t have a full team? No problem — sign up solo and we\'ll help you find a group.</p>\n<p>Consider <a href="{{BASE_URL}}/donate">donating</a> to the Claryville Fire Department!</p>'
  },
  'groups-details': {
    subject: 'The Claryville Open — Groups & Details',
    body: '<h1>Groups Are Set!</h1>\n<p>Check out the current group assignments:</p>\n<p><a href="{{BASE_URL}}/groups">View Groups</a></p>\n<p>If you need to make changes, reply to this email or contact us.</p>'
  },
  'final-call': {
    subject: 'The Claryville Open — Final Call!',
    body: '<h1>Last Chance!</h1>\n<p>The tournament is almost here. This is your last chance to:</p>\n<ul>\n<li>Register or change your group</li>\n<li>Make a donation to the Fire Department</li>\n</ul>\n<p>See you on the course!</p>'
  },
  'recap': {
    subject: 'The Claryville Open — Results & Recap',
    body: '<h1>What a Tournament!</h1>\n<p>Thanks to everyone who came out for the Claryville Open.</p>\n<p><a href="{{BASE_URL}}/leaderboard">View the full leaderboard</a></p>\n<p>See you next year!</p>'
  }
};

function loadTemplate(name) {
  const t = templates[name];
  if (t) {
    document.getElementById('subject').value = t.subject;
    document.getElementById('body').value = t.body;
    updatePreview();
  }
}

function updatePreview() {
  document.getElementById('preview').innerHTML = document.getElementById('body').value;
}

document.getElementById('body')?.addEventListener('input', updatePreview);
</script>
