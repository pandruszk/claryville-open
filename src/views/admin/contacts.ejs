<% layout('layout') -%>
<div class="admin-header">
  <h1>Distribution List (<%= distList.length %>)</h1>
</div>

<nav class="admin-nav">
  <a href="/admin">Dashboard</a>
  <a href="/admin/groups">Groups</a>
  <a href="/admin/inbox">Inbox</a>
  <a href="/admin/email">Email</a>
  <a href="/admin/contacts" class="active">Contacts</a>
  <a href="/admin/scores">Scores</a>
  <a href="/admin/gallery">Gallery</a>
  <a href="/admin/rules-suggestions">Rules</a>
  <a href="/admin/unanswered">Unanswered</a>
  <a href="/admin/past-winners">Winners</a>
</nav>

<section class="admin-section">
  <h2>Add Contact</h2>
  <form method="POST" action="/admin/contacts/add" class="form-inline" style="gap: 0.5rem;">
    <input type="text" name="first_name" placeholder="First name">
    <input type="text" name="last_name" placeholder="Last name">
    <input type="email" name="email" placeholder="Email" required>
    <input type="text" name="clan" placeholder="Clan">
    <button type="submit" class="btn btn-small btn-primary">Add</button>
  </form>
</section>

<section class="admin-section">
  <% if (clans.length > 0) { %>
    <div class="clan-filter" style="margin-bottom: 1rem;">
      <strong style="font-size: 0.82rem; color: var(--gray-500);">Filter by clan:</strong>
      <button class="btn btn-small" onclick="filterClan('')" style="margin-left: 0.25rem;">All (<%= distList.length %>)</button>
      <% for (const clan of clans) { %>
        <button class="btn btn-small" onclick="filterClan('<%= clan %>')"><%= clan %></button>
      <% } %>
    </div>
  <% } %>

  <table class="admin-table" id="contacts-table">
    <thead>
      <tr>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Email</th>
        <th>Clan</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% for (const c of distList) { %>
        <tr data-clan="<%= c.clan || '' %>" id="row-<%= c.id %>">
          <td><%= c.first_name || '—' %></td>
          <td><%= c.last_name || '—' %></td>
          <td><%= c.email %></td>
          <td><%= c.clan || '—' %></td>
          <td class="actions">
            <button class="btn btn-small" onclick="editContact(<%= c.id %>, '<%= (c.first_name || '').replace(/'/g, "\\'") %>', '<%= (c.last_name || '').replace(/'/g, "\\'") %>', '<%= c.email.replace(/'/g, "\\'") %>', '<%= (c.clan || '').replace(/'/g, "\\'") %>')">Edit</button>
            <form method="POST" action="/admin/contacts/<%= c.id %>/delete" class="form-inline" onsubmit="return confirm('Remove from list?')">
              <button type="submit" class="btn btn-small btn-danger">Remove</button>
            </form>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</section>

<!-- Edit modal -->
<div id="edit-modal" class="edit-modal-overlay" style="display:none;">
  <div class="edit-modal">
    <h3>Edit Contact</h3>
    <form id="edit-form" method="POST">
      <div class="form-group">
        <label>First Name</label>
        <input type="text" name="first_name" id="edit-first">
      </div>
      <div class="form-group">
        <label>Last Name</label>
        <input type="text" name="last_name" id="edit-last">
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" id="edit-email" required>
      </div>
      <div class="form-group">
        <label>Clan</label>
        <input type="text" name="clan" id="edit-clan">
      </div>
      <div class="actions" style="gap: 0.5rem; margin-top: 1rem;">
        <button type="submit" class="btn btn-small btn-primary">Save</button>
        <button type="button" class="btn btn-small" onclick="closeEdit()">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function filterClan(clan) {
  const rows = document.querySelectorAll('#contacts-table tbody tr');
  rows.forEach(row => {
    if (!clan || row.dataset.clan === clan) {
      row.style.display = '';
    } else {
      row.style.display = 'none';
    }
  });
}

function editContact(id, first, last, email, clan) {
  document.getElementById('edit-form').action = '/admin/contacts/' + id + '/edit';
  document.getElementById('edit-first').value = first;
  document.getElementById('edit-last').value = last;
  document.getElementById('edit-email').value = email;
  document.getElementById('edit-clan').value = clan;
  document.getElementById('edit-modal').style.display = 'flex';
}

function closeEdit() {
  document.getElementById('edit-modal').style.display = 'none';
}

document.getElementById('edit-modal').addEventListener('click', function(e) {
  if (e.target === this) closeEdit();
});
</script>
