<% layout('layout') -%>
<div class="page-header">
  <h1>Donate</h1>
  <p>Support the Claryville Fire Department</p>
</div>

<% if (success) { %>
  <div class="alert alert-success">Thank you for your generous donation!</div>
<% } %>

<div class="donate-content">
  <div class="card donate-card">
    <h3>Make a Donation</h3>
    <p>All proceeds go directly to the Claryville Fire Department. Any amount is greatly appreciated.</p>

    <% if (stripeConfigured) { %>
      <form method="POST" action="/donate/checkout" class="form donate-form">
        <div class="form-group">
          <label for="amount">Amount ($)</label>
          <input type="number" id="amount" name="amount" min="1" step="1" value="25" required>
        </div>
        <div class="form-group">
          <label for="email">Email <span class="optional">(optional, for receipt)</span></label>
          <input type="email" id="email" name="email">
        </div>
        <button type="submit" class="btn btn-primary">Donate with Card</button>
      </form>
    <% } else { %>
      <div class="alert alert-info">Online donations are not yet configured. Please donate at the event!</div>
    <% } %>
  </div>
</div>
