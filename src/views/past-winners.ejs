<% layout('layout') -%>
<div class="page-header">
  <h1>Past Winners</h1>
  <p>Claryville Open — 4 Person Best Ball</p>
</div>

<div class="page-content">
<div class="trophy-plaque">
  <div class="plaque-title">
    <span>Claryville Open</span>
    <span>Tournament</span>
    <span>4 Person Best Ball</span>
  </div>

  <div class="plaque-grid">
    <% for (const w of winners) { %>
      <div class="plaque-plate">
        <div class="plaque-year"><%= w.year %></div>
        <div class="plaque-names"><%= w.display %></div>
      </div>
    <% } %>
  </div>
</div>

<p class="form-hint" style="margin-top:2rem; text-align:center;">
  Data from the original trophy plaque. Some names may be abbreviated.
</p>
</div>
