<% layout('layout') -%>
<div class="page-header">
  <h1>Register Your Team</h1>
  <p>Enter 1-4 players. Teams with fewer than 4 appear on the "Looking for Group" board.</p>
</div>

<div class="page-content">
<% if (closed) { %>
  <div class="alert alert-info">Registration is currently closed. Check back soon!</div>
<% } else { %>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <% if (success) { %>
    <div class="alert alert-success">You're registered! Check your email for confirmation. View the <a href="/groups">groups page</a> to see your team.</div>
  <% } %>

  <form method="POST" action="/register" class="form register-form">
    <div class="form-group">
      <label for="group_name">Team Name <span class="optional">(optional — we'll generate one from player names)</span></label>
      <input type="text" id="group_name" name="group_name" placeholder="e.g. The Bogey Brothers">
    </div>

    <% for (let i = 1; i <= 4; i++) { %>
      <fieldset class="player-fieldset">
        <legend>Player <%= i %> <% if (i > 1) { %><span class="optional">(optional)</span><% } %></legend>

        <div class="form-row">
          <div class="form-group">
            <label for="p<%= i %>_email">Email <span class="form-hint-inline">— enter to auto-fill</span></label>
            <input type="email" id="p<%= i %>_email" name="p<%= i %>_email" class="contact-email" data-player="<%= i %>" autocomplete="email">
          </div>
          <div class="form-group">
            <label for="p<%= i %>_name">Full Name<% if (i === 1) { %> *<% } %></label>
            <input type="text" id="p<%= i %>_name" name="p<%= i %>_name" <% if (i === 1) { %>required<% } %>>
          </div>
          <div class="form-group">
            <label for="p<%= i %>_display_name">Display Name <span class="form-hint-inline">— shown on site</span></label>
            <input type="text" id="p<%= i %>_display_name" name="p<%= i %>_display_name" placeholder="e.g. Big Pete A.">
          </div>
          <div class="form-group">
            <label for="p<%= i %>_phone">Cell Phone</label>
            <input type="tel" id="p<%= i %>_phone" name="p<%= i %>_phone" placeholder="(555) 555-5555">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group form-group-small">
            <label for="p<%= i %>_age">Age</label>
            <input type="number" id="p<%= i %>_age" name="p<%= i %>_age" min="1" max="110">
          </div>
          <div class="form-group form-group-small">
            <label for="p<%= i %>_gender">Gender</label>
            <select id="p<%= i %>_gender" name="p<%= i %>_gender">
              <option value="">—</option>
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
          <div class="form-group form-group-small">
            <label for="p<%= i %>_ghin">GHIN Index</label>
            <input type="number" id="p<%= i %>_ghin" name="p<%= i %>_ghin" step="0.1" min="-10" max="54" placeholder="optional">
          </div>
        </div>

        <div class="stroke-checkboxes">
          <p class="form-hint">Check all that apply (used for team stroke calculation & tee assignment):</p>
          <div class="checkbox-grid">
            <label class="checkbox-label">
              <input type="checkbox" name="p<%= i %>_is_military" value="1">
              Current/former U.S. military
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="p<%= i %>_never_played_course" value="1">
              Never played golf on a course
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="p<%= i %>_heart_attack_stroke_tumor" value="1">
              Had a heart attack, stroke, or brain tumor
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="p<%= i %>_played_high_school_golf" value="1">
              Played on a high school golf team
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="p<%= i %>_played_college_golf" value="1">
              Played on a college golf team
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="p<%= i %>_played_pga_lpga" value="1">
              Played on the PGA or LPGA Tour
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="p<%= i %>_is_post_partum" value="1">
              Post-partum (within one year of delivery)
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="p<%= i %>_only_plays_claryville" value="1">
              Only plays golf at the Claryville Open
            </label>
          </div>
        </div>
      </fieldset>
    <% } %>

    <button type="submit" class="btn btn-primary">Register</button>
  </form>

  <p class="form-hint" style="margin-top:1rem">
    Team strokes are auto-calculated from player info. See the <a href="/rules">full rules</a> for details.
  </p>
<% } %>
</div>
