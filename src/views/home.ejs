<% layout('layout') -%>
<section class="hero">
  <div class="hero-badge">Est. 1993</div>
  <h1><%= settings.tournament_name || 'The Claryville Open' %></h1>
  <div class="hero-divider"></div>
  <p class="hero-tagline">Annual Family Scramble Tournament</p>
  <div class="hero-details">
    <div class="hero-detail">
      <span class="hero-detail-label">When</span>
      <span class="hero-detail-value"><%= settings.tournament_date || 'Friday, July 3rd, 2026' %></span>
    </div>
    <div class="hero-detail">
      <span class="hero-detail-label">Where</span>
      <span class="hero-detail-value"><%= settings.course_name || 'Lochmor Golf Club' %></span>
    </div>
    <div class="hero-detail">
      <span class="hero-detail-label">Format</span>
      <span class="hero-detail-value">4-Person Best Ball Scramble</span>
    </div>
  </div>
  <div class="hero-actions">
    <a href="/register" class="btn btn-primary btn-lg">Register Your Team</a>
    <a href="/rules" class="btn btn-secondary">View Rules</a>
  </div>
</section>

<section class="home-section">
  <div class="info-cards">
    <div class="card card-accent">
      <div class="card-icon">&#9971;</div>
      <h3>Scramble Format</h3>
      <p>4-person best ball. Grab your family and friends — all skill levels welcome. Custom stroke rules keep it fair and fun.</p>
    </div>
    <div class="card card-accent">
      <div class="card-icon">&#9997;</div>
      <h3>Sign Up</h3>
      <p>Register as a group of 1-4 players. Solo players and incomplete teams can find partners on the <a href="/groups">Groups</a> page.</p>
    </div>
    <div class="card card-accent">
      <div class="card-icon">&#127942;</div>
      <h3>Prizes</h3>
      <p>Low net, low gross, high net, closest to pin, and longest drive. Get your name on the plaque!</p>
    </div>
    <div class="card card-accent">
      <div class="card-icon">&#128293;</div>
      <h3>Give Back</h3>
      <p>All donations support the Claryville Fire Department. <a href="/donate">Donate here</a> — every dollar counts.</p>
    </div>
  </div>
</section>

<section class="home-section home-history">
  <h2 class="section-title">30+ Years of Tradition</h2>
  <p class="section-desc">Since 1993, the Claryville Open has brought together family and friends for a day of golf, laughs, and friendly competition. Check out the <a href="/past-winners">past winners</a> engraved on the trophy.</p>
  <div class="history-stats">
    <div class="history-stat">
      <span class="history-stat-number">30+</span>
      <span class="history-stat-label">Years</span>
    </div>
    <div class="history-stat">
      <span class="history-stat-number">100s</span>
      <span class="history-stat-label">Players</span>
    </div>
    <div class="history-stat">
      <span class="history-stat-number">1</span>
      <span class="history-stat-label">Trophy</span>
    </div>
  </div>
  <a href="/past-winners" class="btn btn-primary">View Past Winners</a>
</section>
